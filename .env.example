# Dashboard (Next.js) - safe to expose, read-only via RLS
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Pipeline (Python) - secret, set as GitHub Actions secrets in CI
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SECRET_KEY=sb_secret_...

# LLM enrichment (optional). Set one; Groq is preferred (free, no billing).
# The pipeline runs fine on rule-based enrichment if neither is set.
GROQ_API_KEY=gsk_...
GEMINI_API_KEY=...
